{% extends 'base.html.twig' %}

{% block title %}Modifier {{ vehicle.immatriculation }} - ParcAuto{% endblock %}

{% block page_icon 'pencil-square' %}

{% block page_title %}Modifier le véhicule{% endblock %}

{% block page_description %}
    Mettez à jour les informations du véhicule {{ vehicle.immatriculation }}
{% endblock %}

{% block page_actions %}
    <div class="d-flex gap-2">
        <a href="{{ path('app_vehicle_index') }}" class="btn btn-outline-secondary d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left"></i>
            <span>Retour à la liste</span>
        </a>
        <a href="{{ path('app_vehicle_show', {'id': vehicle.id}) }}" class="btn btn-outline-danger d-flex align-items-center gap-2">
            <i class="bi bi-eye"></i>
            <span>Voir les détails</span>
        </a>
    </div>
{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <!-- Carte d'édition -->
        <div class="card border-0 shadow-lg mb-4">
            <div class="card-header bg-white border-0 py-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 50px; height: 50px;">
                        <i class="bi bi-car-front fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-1">Modification du véhicule</h5>
                        <p class="text-muted mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Modifiez les champs nécessaires ci-dessous
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-4 p-lg-5">
                {{ include('vehicle/_form.html.twig', {
                    'button_label': 'Mettre à jour',
                    'button_icon': 'save'
                }) }}
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Informations actuelles -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-4">
                <h5 class="mb-0 text-danger fw-semibold">
                    <i class="bi bi-info-circle me-2"></i>
                    Informations actuelles
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="small text-muted mb-2">Immatriculation</div>
                    <div class="fw-semibold">{{ vehicle.immatriculation }}</div>
                </div>
                
                <div class="mb-3">
                    <div class="small text-muted mb-2">Modèle</div>
                    <div class="fw-semibold">{{ vehicle.modele }}</div>
                </div>
                
                <div class="mb-3">
                    <div class="small text-muted mb-2">État actuel</div>
                    <div>
                        {% if vehicle.etat == 'Disponible' %}
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3">
                                Disponible
                            </span>
                        {% elseif vehicle.etat == 'En panne' %}
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3">
                                En panne
                            </span>
                        {% elseif vehicle.etat == 'En service' %}
                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3">
                                En service
                            </span>
                        {% elseif vehicle.etat == 'Affecté' %}
                            <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill px-3">
                                Affecté
                            </span>
                        {% else %}
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3">
                                {{ vehicle.etat }}
                            </span>
                        {% endif %}
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="small text-muted mb-2">Kilométrage actuel</div>
                    <div class="fw-semibold">{{ vehicle.kilometrage | number_format(0, ',', ' ') }} km</div>
                </div>
                
                <div class="mt-4 pt-3 border-top">
                    <div class="small text-muted mb-2">ID du véhicule</div>
                    <div class="fw-semibold">#{{ vehicle.id }}</div>
                </div>
            </div>
        </div>
        
        <!-- Actions dangereuses -->
        <div class="card border-0 shadow-sm border-start border-4 border-danger">
            <div class="card-header bg-white border-0 py-4">
                <h5 class="mb-0 text-danger fw-semibold">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Actions dangereuses
                </h5>
            </div>
            <div class="card-body">
                <p class="small text-muted mb-3">
                    Ces actions sont irréversibles. Soyez certain de votre choix.
                </p>
                
                <div class="d-grid gap-2">
                    <button type="button" 
                            class="btn btn-outline-danger d-flex align-items-center justify-content-between p-3"
                            data-bs-toggle="modal" 
                            data-bs-target="#deleteModal">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 40px; height: 40px;">
                                <i class="bi bi-trash"></i>
                            </div>
                            <div class="text-start">
                                <div class="fw-semibold">Supprimer ce véhicule</div>
                                <div class="small text-muted">Action irréversible</div>
                            </div>
                        </div>
                        <i class="bi bi-chevron-right"></i>
                    </button>
                    
                    <button type="button" 
                            class="btn btn-outline-warning d-flex align-items-center justify-content-between p-3"
                            id="resetAllBtn">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 40px; height: 40px;">
                                <i class="bi bi-arrow-clockwise"></i>
                            </div>
                            <div class="text-start">
                                <div class="fw-semibold">Réinitialiser le formulaire</div>
                                <div class="small text-muted">Annuler toutes les modifications</div>
                            </div>
                        </div>
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- Guide de modification -->
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white border-0 py-4">
                <h5 class="mb-0 text-danger fw-semibold">
                    <i class="bi bi-lightbulb me-2"></i>
                    Conseils de modification
                </h5>
            </div>
            <div class="card-body">
                <div class="small">
                    <div class="mb-3">
                        <h6 class="fw-semibold mb-2">
                            <i class="bi bi-check-circle text-success me-1"></i>
                            Bonnes pratiques
                        </h6>
                        <ul class="text-muted ps-3 mb-0">
                            <li class="mb-1">Mettez à jour le kilométrage régulièrement</li>
                            <li class="mb-1">Modifiez l'état dès qu'il change</li>
                            <li>Vérifiez l'exactitude des informations</li>
                        </ul>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="fw-semibold mb-2">
                            <i class="bi bi-exclamation-triangle text-warning me-1"></i>
                            À éviter
                        </h6>
                        <ul class="text-muted ps-3 mb-0">
                            <li class="mb-1">Modifications fréquentes inutiles</li>
                            <li class="mb-1">Informations erronées ou approximatives</li>
                            <li>Oublier de sauvegarder les modifications</li>
                        </ul>
                    </div>
                    
                    <div>
                        <h6 class="fw-semibold mb-2">
                            <i class="bi bi-clock-history text-primary me-1"></i>
                            Suivi des modifications
                        </h6>
                        <p class="text-muted small mb-0">
                            Toutes les modifications sont enregistrées dans le système pour assurer la traçabilité.
                        </p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Restaurer les valeurs originales -->
        <div class="card border-0 bg-light mt-4">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 40px; height: 40px;">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </div>
                    <div class="small">
                        <div class="fw-semibold">Valeurs originales</div>
                        <div class="text-muted">
                            Conservez les valeurs actuelles en mémoire avant de modifier
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de suppression -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 40px; height: 40px;">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div>
                        <h5 class="modal-title text-danger mb-0">Supprimer le véhicule</h5>
                        <p class="text-muted small mb-0">{{ vehicle.immatriculation }}</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body py-4">
                <p class="mb-3">Êtes-vous sûr de vouloir supprimer ce véhicule ?</p>
                
                <div class="alert alert-warning small">
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi bi-info-circle"></i>
                        <div>
                            <strong>Attention :</strong> Cette action supprimera également tous les entretiens et affectations associés.
                        </div>
                    </div>
                </div>
                
                <form method="post" action="{{ path('app_vehicle_delete', {'id': vehicle.id}) }}" class="mt-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vehicle.id) }}">
                    
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Annuler
                        </button>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>
                            Supprimer définitivement
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Scripts supplémentaires -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Réinitialisation complète du formulaire
        document.getElementById('resetAllBtn').addEventListener('click', function() {
            if (confirm('Êtes-vous sûr de vouloir réinitialiser toutes les modifications ? Cette action ne peut pas être annulée.')) {
                document.querySelector('form').reset();
                // Retirer les classes de validation
                document.querySelectorAll('.is-invalid').forEach(el => {
                    el.classList.remove('is-invalid');
                });
                document.querySelectorAll('.invalid-feedback').forEach(el => {
                    el.style.display = 'none';
                });
                document.querySelector('form').classList.remove('was-validated');
                
                // Afficher un message de confirmation
                const alert = document.createElement('div');
                alert.className = 'alert alert-success alert-dismissible fade show mt-3';
                alert.innerHTML = `
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>Formulaire réinitialisé avec succès</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.card-body').prepend(alert);
                
                // Auto-dismiss après 3 secondes
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 3000);
            }
        });

        // Stocker les valeurs originales
        const originalValues = {
            immatriculation: '{{ vehicle.immatriculation|escape('js') }}',
            modele: '{{ vehicle.modele|escape('js') }}',
            etat: '{{ vehicle.etat|escape('js') }}',
            kilometrage: '{{ vehicle.kilometrage|escape('js') }}'
        };

        // Bouton pour restaurer les valeurs originales
        const restoreBtn = document.createElement('button');
        restoreBtn.type = 'button';
        restoreBtn.className = 'btn btn-outline-primary btn-sm d-flex align-items-center gap-2 mt-3 w-100';
        restoreBtn.innerHTML = `
            <i class="bi bi-arrow-counterclockwise"></i>
            <span>Restaurer les valeurs originales</span>
        `;
        restoreBtn.addEventListener('click', function() {
            if (confirm('Restaurer les valeurs originales du véhicule ? Les modifications en cours seront perdues.')) {
                document.querySelector('#vehicle_form_immatriculation').value = originalValues.immatriculation;
                document.querySelector('#vehicle_form_modele').value = originalValues.modele;
                document.querySelector('#vehicle_form_etat').value = originalValues.etat;
                document.querySelector('#vehicle_form_kilometrage').value = originalValues.kilometrage;
                
                // Afficher un message de confirmation
                const alert = document.createElement('div');
                alert.className = 'alert alert-info alert-dismissible fade show mt-3';
                alert.innerHTML = `
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-info-circle-fill"></i>
                        <div>Valeurs originales restaurées</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                document.querySelector('.card-body').prepend(alert);
                
                setTimeout(() => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                }, 3000);
            }
        });

        // Ajouter le bouton après les conseils
        const guideCard = document.querySelector('.card-body');
        if (guideCard) {
            guideCard.appendChild(restoreBtn);
        }

        // Détecter les modifications
        const form = document.querySelector('form');
        const inputs = form.querySelectorAll('input, select, textarea');
        let hasChanges = false;

        inputs.forEach(input => {
            const originalValue = input.value;
            input.addEventListener('input', function() {
                hasChanges = true;
                // Mettre à jour l'indicateur visuel
                this.classList.add('is-modified');
            });
            
            input.addEventListener('change', function() {
                if (this.value !== originalValue) {
                    hasChanges = true;
                    this.classList.add('is-modified');
                }
            });
        });

        // Avertir avant de quitter la page si des modifications non sauvegardées
        window.addEventListener('beforeunload', function(e) {
            if (hasChanges) {
                e.preventDefault();
                e.returnValue = 'Vous avez des modifications non sauvegardées. Êtes-vous sûr de vouloir quitter ?';
            }
        });

        // Réinitialiser hasChanges lors de la soumission
        form.addEventListener('submit', function() {
            hasChanges = false;
        });
    });
</script>

<style>
    .card {
        border-radius: 12px;
    }
    
    .btn-outline-danger:hover {
        background-color: rgba(220, 38, 38, 0.1);
    }
    
    .btn-outline-warning:hover {
        background-color: rgba(245, 158, 11, 0.1);
    }
    
    .modal-content {
        border-radius: 12px;
    }
    
    .badge {
        font-weight: 500;
    }
    
    .border-danger {
        border-color: #dc2626 !important;
    }
    
    .bg-light {
        background-color: #f8f9fa !important;
    }
    
    .bg-opacity-10 {
        opacity: 0.1;
    }
    
    .is-modified {
        border-left: 4px solid #0d6efd !important;
        background-color: rgba(13, 110, 253, 0.05) !important;
    }
    
    .list-unstyled li {
        margin-bottom: 0.5rem;
    }
    
    .btn-outline-primary:hover {
        background-color: rgba(13, 110, 253, 0.1);
    }
</style>
{% endblock %}