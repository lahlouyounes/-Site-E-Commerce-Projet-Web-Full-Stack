{% extends 'base.html.twig' %}

{% block title %}Nouveau véhicule - ParcAuto{% endblock %}

{% block page_icon 'plus-circle' %}

{% block page_title %}Ajouter un véhicule{% endblock %}

{% block page_description %}
    Remplissez le formulaire pour ajouter un nouveau véhicule au parc automobile
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_vehicle_index') }}" class="btn btn-outline-secondary d-flex align-items-center gap-2">
        <i class="bi bi-arrow-left"></i>
        <span>Retour à la liste</span>
    </a>
{% endblock %}

{% block body %}
<div class="row">
    <div class="col-lg-8">
        <!-- Carte principale du formulaire -->
        <div class="card border-0 shadow-lg">
            <div class="card-header bg-white border-0 py-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 50px; height: 50px;">
                        <i class="bi bi-car-front fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-1">Nouveau véhicule</h5>
                        <p class="text-muted mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Tous les champs marqués d'un <span class="text-danger">*</span> sont obligatoires
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-4 p-lg-5">
                {{ include('vehicle/_form.html.twig', {
                    'button_label': 'Créer le véhicule',
                    'button_icon': 'plus-circle'
                }) }}
            </div>
        </div>
    </div>
    
    <div class="col-lg-4">
        <!-- Guide d'aide -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 py-4">
                <h5 class="mb-0 text-danger fw-semibold">
                    <i class="bi bi-lightbulb me-2"></i>
                    Guide de saisie
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h6 class="fw-semibold mb-3 text-dark">
                        <i class="bi bi-card-checklist text-primary me-2"></i>
                        Champs obligatoires
                    </h6>
                    <ul class="small text-muted ps-3 mb-0">
                        <li class="mb-2">
                            <strong>Immatriculation</strong> - Format officiel (ex: AB-123-CD)
                        </li>
                        <li class="mb-2">
                            <strong>Modèle</strong> - Modèle complet du véhicule
                        </li>
                        <li class="mb-2">
                            <strong>État</strong> - Sélectionnez le statut approprié
                        </li>
                        <li>
                            <strong>Kilométrage</strong> - Valeur actuelle en kilomètres
                        </li>
                    </ul>
                </div>
                
                <div class="mb-4">
                    <h6 class="fw-semibold mb-3 text-dark">
                        <i class="bi bi-star text-warning me-2"></i>
                        Recommandations
                    </h6>
                    <ul class="small text-muted ps-3 mb-0">
                        <li class="mb-2">
                            Vérifiez l'exactitude de l'immatriculation
                        </li>
                        <li class="mb-2">
                            Mettez à jour le kilométrage régulièrement
                        </li>
                        <li>
                            Choisissez l'état approprié pour faciliter le suivi
                        </li>
                    </ul>
                </div>
                
                <div>
                    <h6 class="fw-semibold mb-3 text-dark">
                        <i class="bi bi-shield-check text-success me-2"></i>
                        Sécurité
                    </h6>
                    <ul class="small text-muted ps-3 mb-0">
                        <li class="mb-2">
                            Les données sont cryptées et sécurisées
                        </li>
                        <li class="mb-2">
                            Historique complet des modifications conservé
                        </li>
                        <li>
                            Conformité RGPD garantie
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        
        <!-- Exemples de véhicules -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 py-4">
                <h5 class="mb-0 text-danger fw-semibold">
                    <i class="bi bi-car-front me-2"></i>
                    Exemples de saisie
                </h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="small text-muted mb-2">Véhicule de service</div>
                    <div class="d-flex align-items-center gap-2 p-3 bg-light rounded">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 36px; height: 36px;">
                            <i class="bi bi-car-front"></i>
                        </div>
                        <div class="small">
                            <div class="fw-semibold">AB-789-XY</div>
                            <div class="text-muted">Renault Kangoo - 45 000 km</div>
                        </div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="small text-muted mb-2">Véhicule direction</div>
                    <div class="d-flex align-items-center gap-2 p-3 bg-light rounded">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 36px; height: 36px;">
                            <i class="bi bi-car-front"></i>
                        </div>
                        <div class="small">
                            <div class="fw-semibold">CD-456-EF</div>
                            <div class="text-muted">Peugeot 508 - 12 500 km</div>
                        </div>
                    </div>
                </div>
                
                <div>
                    <div class="small text-muted mb-2">Véhicule technique</div>
                    <div class="d-flex align-items-center gap-2 p-3 bg-light rounded">
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 36px; height: 36px;">
                            <i class="bi bi-truck"></i>
                        </div>
                        <div class="small">
                            <div class="fw-semibold">EF-123-GH</div>
                            <div class="text-muted">Renault Master - 89 000 km</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Lien rapide -->
        <div class="card border-0 bg-danger bg-opacity-5 mt-4 border-start border-4 border-danger">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 40px; height: 40px;">
                        <i class="bi bi-question-circle"></i>
                    </div>
                    <div class="small">
                        <div class="fw-semibold">Besoin d'aide ?</div>
                        <div class="text-muted">
                            Consultez le 
                            <a href="#" class="text-danger fw-semibold">guide d'utilisation</a>
                            ou contactez l'administrateur
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Script supplémentaire pour la création -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Focus automatique sur le premier champ
        const firstInput = document.querySelector('form input:not([type="hidden"])');
        if (firstInput) {
            firstInput.focus();
        }
        
        // Validation en temps réel
        const inputs = document.querySelectorAll('.form-control, .form-select');
        inputs.forEach(input => {
            input.addEventListener('blur', function() {
                if (this.value.trim() === '') {
                    this.classList.add('is-invalid');
                } else {
                    this.classList.remove('is-invalid');
                    this.classList.add('is-valid');
                }
            });
        });
    });
</script>

<style>
    .card {
        border-radius: 12px;
    }
    
    .bg-danger.bg-opacity-5 {
        background-color: rgba(220, 38, 38, 0.05) !important;
    }
    
    .border-danger {
        border-color: #dc2626 !important;
    }
    
    .form-control.is-valid {
        border-color: #10b981;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 8 8'%3e%3cpath fill='%2310b981' d='M2.3 6.73L.6 4.53c-.4-1.04.46-1.4 1.1-.8l1.1 1.4 3.4-3.8c.6-.63 1.6-.27 1.2.7l-4 4.6c-.43.5-.8.4-1.1.1z'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right calc(0.375em + 0.1875rem) center;
        background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem);
    }
    
    .alert {
        border-radius: 8px;
        border: none;
    }
    
    .btn-sm {
        padding: 0.375rem 0.875rem;
        font-size: 0.875rem;
    }
    
    .list-unstyled li {
        margin-bottom: 0.5rem;
    }
    
    .bg-light.rounded {
        border-radius: 8px !important;
    }
</style>
{% endblock %}