<!-- Scripts pour améliorer l'UX -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Validation Bootstrap
        var forms = document.querySelectorAll('.needs-validation');
        Array.prototype.slice.call(forms).forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });

        // Effet de focus sur les champs
        const inputs = document.querySelectorAll('.form-control, .form-select');
        inputs.forEach(input => {
            input.addEventListener('focus', function() {
                this.parentElement.classList.add('focused');
            });
            
            input.addEventListener('blur', function() {
                this.parentElement.classList.remove('focused');
            });
        });

        // Confirmation avant réinitialisation
        document.getElementById('resetBtn').addEventListener('click', function(e) {
            if (!confirm('Êtes-vous sûr de vouloir réinitialiser le formulaire ? Toutes les modifications seront perdues.')) {
                e.preventDefault();
            }
        });

        // Animation sur soumission
        const submitBtn = document.getElementById('submitBtn');
        const form = document.querySelector('form');
        
        if (form && submitBtn) {
            form.addEventListener('submit', function() {
                submitBtn.innerHTML = `
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    Enregistrement en cours...
                `;
                submitBtn.disabled = true;
            });
        }

        // Masquer les messages d'erreur au focus
        inputs.forEach(input => {
            input.addEventListener('focus', function() {
                this.classList.remove('is-invalid');
                const feedback = this.nextElementSibling;
                if (feedback && feedback.classList.contains('invalid-feedback')) {
                    feedback.style.display = 'none';
                }
            });
        });
        
        // Amélioration du sélecteur d'état (mise à jour pour inclure orange)
        const etatSelect = document.querySelector('#{{ form.etat.vars.id }}');
        if (etatSelect) {
            etatSelect.addEventListener('change', function() {
                // Ajouter une classe selon la valeur sélectionnée
                this.classList.remove('border-success', 'border-danger', 'border-warning', 'border-info', 'border-orange', 'border-dark');
                
                if (this.value === 'Disponible') {
                    this.classList.add('border-success');
                } else if (this.value === 'En panne') {
                    this.classList.add('border-danger');
                } else if (this.value === 'En service') {
                    this.classList.add('border-warning');
                } else if (this.value === 'Affecté') {
                    this.classList.add('border-info');
                } else if (this.value === 'En révision') {
                    this.classList.add('border-orange');
                } else if (this.value === 'Hors service') {
                    this.classList.add('border-dark');
                }
            });
            
            // Déclencher l'événement au chargement
            etatSelect.dispatchEvent(new Event('change'));
            
            // Ajouter un placeholder vide comme première option
            if (!etatSelect.querySelector('option[value=""]')) {
                const emptyOption = document.createElement('option');
                emptyOption.value = '';
                emptyOption.textContent = 'Sélectionnez un état';
                emptyOption.disabled = true;
                emptyOption.selected = true;
                etatSelect.insertBefore(emptyOption, etatSelect.firstChild);
            }
        }
    });
</script>

